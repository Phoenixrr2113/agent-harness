{
  "name": "agent-harness",
  "version": "0.1.0",
  "description": "A file-first agent operating system. Build AI agents by editing markdown files, not writing code.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harness": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist",
    "defaults",
    "templates",
    "sources.yaml"
  ],
  "keywords": [
    "ai",
    "agent",
    "harness",
    "autonomous",
    "llm",
    "openrouter",
    "framework"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/mcp": "^1.0.32",
    "@ai-sdk/openai": "^3.0.50",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.146",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "gray-matter": "^4.0.3",
    "node-cron": "^4.2.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
